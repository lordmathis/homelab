# Agentkit service

PLIST_NAME := "lab.agentkit.plist"
PLIST_SRC  := justfile_directory() / PLIST_NAME
PLIST_DST  := env_var("HOME") / "Library/LaunchAgents" / PLIST_NAME

# Show available commands
default:
    @just --list --unsorted

# Start the agentkit service
start:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p "$HOME/Library/LaunchAgents" "$HOME/Library/Logs/agentkit"
    [ -e "{{ PLIST_DST }}" ] && launchctl unload "{{ PLIST_DST }}" 2>/dev/null || true
    ln -sf "{{ PLIST_SRC }}" "{{ PLIST_DST }}"
    launchctl load "{{ PLIST_DST }}"
    echo "Agentkit service started"

# Stop the agentkit service
stop:
    #!/usr/bin/env bash
    set -euo pipefail
    launchctl unload "{{ PLIST_DST }}" 2>/dev/null || true
    rm -f "{{ PLIST_DST }}"
    echo "Agentkit service stopped"

# Install/update gitea-mcp binary
update-mcps:
    #!/usr/bin/env bash
    set -euo pipefail
    INSTALL_PATH="$HOME/bin/gitea-mcp"
    command -v curl >/dev/null 2>&1 || { echo "curl required"; exit 1; }
    command -v tar >/dev/null 2>&1 || { echo "tar required"; exit 1; }
    LATEST_VERSION=$(curl -s https://gitea.com/api/v1/repos/gitea/gitea-mcp/releases/latest | grep -o '"tag_name":"[^"]*"' | cut -d'"' -f4)
    DOWNLOAD_URL="https://gitea.com/gitea/gitea-mcp/releases/download/${LATEST_VERSION}/gitea-mcp_Darwin_arm64.tar.gz"
    if [ -f "$INSTALL_PATH" ]; then
        echo "Removing existing installation..."
        rm "$INSTALL_PATH"
    fi
    mkdir -p "$(dirname "$INSTALL_PATH")"
    cd /tmp
    echo "Downloading gitea-mcp from $DOWNLOAD_URL..."
    curl -L -o gitea-mcp.tar.gz "$DOWNLOAD_URL"
    tar -xzf gitea-mcp.tar.gz
    cp gitea-mcp "$INSTALL_PATH"
    chmod +x "$INSTALL_PATH"
    if [ -f "$INSTALL_PATH" ]; then
        xattr -dr com.apple.quarantine "$INSTALL_PATH" 2>/dev/null || true
    fi
    PARENT_DIR=$(dirname "$INSTALL_PATH")
    SHELL_CONFIG="${HOME}/.zshrc"
    [[ $SHELL == */bash ]] && SHELL_CONFIG="${HOME}/.bash_profile"
    if ! grep -q "$PARENT_DIR" "$SHELL_CONFIG" 2>/dev/null; then
        echo "export PATH=\"\$PATH:$PARENT_DIR\"" >> "$SHELL_CONFIG"
        echo "Added $PARENT_DIR to PATH in $SHELL_CONFIG"
    else
        echo "$PARENT_DIR is already in PATH"
    fi
    rm -rf /tmp/gitea-mcp /tmp/gitea-mcp.tar.gz
    echo "Done. Installed to $INSTALL_PATH"